<Application x:Class="Pickets.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <!--
            Unified dark chrome for context menus, shared by the title menu, item menus, and
            label menu. Matches the tooltip pill style (#F01E1E1E + white text + rounded 4px)
            so the app's secondary UI reads as a single visual language regardless of which
            fence color the user picked. Lives in App.xaml so every ContextMenu instance in
            every fence picks it up automatically; no per-menu tagging required.
        -->

        <!-- Shared palette. Defined as resources so a future dark/light toggle only needs to
             flip a handful of values rather than chase hex literals. -->
        <Color x:Key="MenuBackgroundColor">#F01E1E1E</Color>
        <Color x:Key="MenuBorderColor">#FF000000</Color>
        <Color x:Key="MenuForegroundColor">#FFFFFFFF</Color>
        <Color x:Key="MenuHoverColor">#40FFFFFF</Color>
        <Color x:Key="MenuSeparatorColor">#40FFFFFF</Color>
        <Color x:Key="MenuDisabledForegroundColor">#80FFFFFF</Color>

        <SolidColorBrush x:Key="MenuBackgroundBrush"         Color="{StaticResource MenuBackgroundColor}"/>
        <SolidColorBrush x:Key="MenuBorderBrush"             Color="{StaticResource MenuBorderColor}"/>
        <SolidColorBrush x:Key="MenuForegroundBrush"         Color="{StaticResource MenuForegroundColor}"/>
        <SolidColorBrush x:Key="MenuHoverBrush"              Color="{StaticResource MenuHoverColor}"/>
        <SolidColorBrush x:Key="MenuSeparatorBrush"          Color="{StaticResource MenuSeparatorColor}"/>
        <SolidColorBrush x:Key="MenuDisabledForegroundBrush" Color="{StaticResource MenuDisabledForegroundColor}"/>

        <!-- ContextMenu: rounded dark pill wrapper. Padding=4 keeps items from kissing the
             border; HasDropShadow adds a subtle elevation so the menu reads as floating rather
             than painted onto the fence. -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="{StaticResource MenuBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource MenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{StaticResource MenuForegroundBrush}"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="HasDropShadow"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="6">
                            <!-- Soft shadow gives the menu a sense of elevation against both
                                 the fence and the wallpaper; Margin=6 on the Border leaves room
                                 for the blur to render without being clipped by the Popup bounds. -->
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.45"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator inside menus: faint horizontal rule. Pure-white dividers blow out on a
             dark background; 25% alpha is enough to group items without becoming chrome. -->
        <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="6,4"/>
            <Setter Property="Background" Value="{StaticResource MenuSeparatorBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template pieces for MenuItem. WPF MenuItem requires separate templates per Role:
             SubmenuItem (leaf in a popup), SubmenuHeader (item whose child is another popup).
             TopLevelHeader/Item are for menubar-hosted items; we never use those. -->

        <ControlTemplate x:Key="SubmenuItemTemplate" TargetType="MenuItem">
            <Border x:Name="Bg"
                    Background="Transparent"
                    CornerRadius="3"
                    Padding="8,4"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon slot shows the MenuItem.Icon content (e.g. color swatches) when
                         IsChecked=false; swaps to a check glyph when IsChecked=true. -->
                    <ContentPresenter x:Name="IconHost"
                                      Grid.Column="0"
                                      ContentSource="Icon"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CheckGlyph"
                               Grid.Column="0"
                               Text="&#xE73E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="{StaticResource MenuForegroundBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>

                    <ContentPresenter Grid.Column="1"
                                      ContentSource="Header"
                                      RecognizesAccessKey="True"
                                      VerticalAlignment="Center"
                                      Margin="6,0,8,0"
                                      TextBlock.Foreground="{StaticResource MenuForegroundBrush}"/>

                    <!-- InputGestureText slot. We don't use gesture strings currently, but keeping
                         the column means future Ctrl+X-style hints have a spot without reflowing. -->
                    <TextBlock Grid.Column="2"
                               Text="{TemplateBinding InputGestureText}"
                               Foreground="{StaticResource MenuDisabledForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource MenuHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="IconHost"   Property="Visibility" Value="Collapsed"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource MenuDisabledForegroundBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SubmenuHeaderTemplate" TargetType="MenuItem">
            <Border x:Name="Bg"
                    Background="Transparent"
                    CornerRadius="3"
                    Padding="8,4"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0"
                                      ContentSource="Icon"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                    <ContentPresenter Grid.Column="1"
                                      ContentSource="Header"
                                      RecognizesAccessKey="True"
                                      VerticalAlignment="Center"
                                      Margin="6,0,8,0"
                                      TextBlock.Foreground="{StaticResource MenuForegroundBrush}"/>
                    <!-- MDL2 chevron glyph; matches the iconography used elsewhere in the title bar. -->
                    <TextBlock Grid.Column="2"
                               Text="&#xE76C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"
                               Foreground="{StaticResource MenuDisabledForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>

                    <!-- The actual submenu Popup is hosted here. Styling its own border/background
                         matches the outer ContextMenu so nested menus feel like one surface. -->
                    <Popup x:Name="PART_Popup"
                           Placement="Right"
                           HorizontalOffset="-4"
                           IsOpen="{TemplateBinding IsSubmenuOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                        <Border Background="{StaticResource MenuBackgroundBrush}"
                                BorderBrush="{StaticResource MenuBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="4"
                                Margin="6">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.45"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource MenuHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource MenuDisabledForegroundBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- MenuItem style. Role-based template selection via DataTrigger so the same Style works
             for both leaf items and submenu headers without per-item tagging. -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground"    Value="{StaticResource MenuForegroundBrush}"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template"      Value="{StaticResource SubmenuItemTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Template" Value="{StaticResource SubmenuHeaderTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Separator" BasedOn="{StaticResource MenuSeparatorStyle}"/>

    </Application.Resources>
</Application>
