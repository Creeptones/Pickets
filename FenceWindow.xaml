<Window x:Class="Pickets.FenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Pickets"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MinWidth="160" MinHeight="40"
        Title="Fence"
        UseLayoutRounding="True">
    <Window.Resources>
        <ContextMenu x:Key="ItemContextMenu">
            <MenuItem Header="Open" Click="ItemMenu_Open_Click"/>
            <MenuItem Header="Open file location" Click="ItemMenu_OpenLocation_Click"/>
            <MenuItem Header="Large icon (2x2)" Tag="LargeToggle" IsCheckable="True" Click="ItemMenu_ToggleLarge_Click"/>
            <Separator/>
            <MenuItem Header="Insert label above..." Click="ItemMenu_InsertLabelAbove_Click"/>
            <MenuItem Header="Remove from fence (restore icon)" Click="ItemMenu_Remove_Click"/>
        </ContextMenu>
        <ContextMenu x:Key="LabelContextMenu">
            <MenuItem Header="Rename label..." Click="LabelMenu_Rename_Click"/>
            <MenuItem Header="Remove label" Click="LabelMenu_Remove_Click"/>
        </ContextMenu>
        <ContextMenu x:Key="TitleContextMenu">
            <MenuItem Header="Rename fence..." Click="TitleMenu_Rename_Click"/>
            <MenuItem Header="Roll up / down" Click="TitleMenu_ToggleCollapse_Click"/>
            <MenuItem Header="Color" Tag="ColorMenu">
                <MenuItem Header="White" Tag="white" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#FFFFFF" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Stone" Tag="stone" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#EDEDED" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Cloud" Tag="cloud" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F2F4F7" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Sand" Tag="sand" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F0EBDF" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Sage" Tag="sage" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#E2EAE0" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Sky" Tag="sky" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#E0E8F0" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Blush" Tag="blush" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F0E2E2" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Lilac" Tag="lilac" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#E5E0EC" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Mint" Tag="mint" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#DEEAE3" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Peach" Tag="peach" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F5E1CE" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Apricot" Tag="apricot" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F5D2B0" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Butter" Tag="butter" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F5EECE" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Coral" Tag="coral" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F5D6CE" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Rose" Tag="rose" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#F2CED8" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Teal" Tag="teal" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#D4E6E4" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Periwinkle" Tag="periwinkle" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#DCDEF0" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Slate" Tag="slate" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#2B3540" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Charcoal" Tag="charcoal" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#2E2E2E" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Black" Tag="black" IsCheckable="True" Click="TitleMenu_SetColor_Click">
                    <MenuItem.Icon><Rectangle Width="14" Height="14" Fill="#000000" Stroke="#888" StrokeThickness="1"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Transparency" Tag="TransparencyMenu">
                <MenuItem Header="Solid (100%)" Tag="solid"  IsCheckable="True" Click="TitleMenu_SetTransparency_Click"/>
                <MenuItem Header="Light (65%)"  Tag="light"  IsCheckable="True" Click="TitleMenu_SetTransparency_Click"/>
                <MenuItem Header="Medium (40%)" Tag="medium" IsCheckable="True" Click="TitleMenu_SetTransparency_Click"/>
                <MenuItem Header="Heavy (20%)"  Tag="heavy"  IsCheckable="True" Click="TitleMenu_SetTransparency_Click"/>
                <Separator/>
                <MenuItem Tag="custom" StaysOpenOnClick="True" IsCheckable="True">
                    <MenuItem.Header>
                        <StackPanel Orientation="Vertical" Width="200" Margin="0,2">
                            <TextBlock Tag="CustomLabel" Text="Custom: 50%" Margin="0,0,0,2"/>
                            <Slider Tag="CustomSlider"
                                    Minimum="0" Maximum="100" Value="50"
                                    Width="190" TickFrequency="5"
                                    ValueChanged="TransparencyCustomSlider_ValueChanged"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Blur background (Win10+)" Tag="BlurToggle" IsCheckable="True" Click="TitleMenu_ToggleBlur_Click"/>
            <Separator/>
            <MenuItem Header="Add section label..." Click="TitleMenu_AddLabel_Click"/>
            <Separator/>
            <MenuItem Header="Convert to folder portal..." Tag="ConvertToPortal" Click="TitleMenu_ConvertToPortal_Click"/>
            <MenuItem Header="Open folder in Explorer" Tag="OpenPortalFolder" Click="TitleMenu_OpenPortalFolder_Click"/>
            <MenuItem Header="Disconnect portal" Tag="DisconnectPortal" Click="TitleMenu_DisconnectPortal_Click"/>
            <Separator/>
            <MenuItem Header="New fence here" Click="TitleMenu_NewFence_Click"/>
            <MenuItem Header="Delete this fence" Click="TitleMenu_DeleteFence_Click"/>
            <MenuItem Header="Clean up missing items" Click="TitleMenu_CleanMissing_Click"/>
            <Separator/>
            <MenuItem Header="Hide / show all fences (Ctrl+Alt+D or double-click desktop)" Click="TitleMenu_HideAll_Click"/>
            <MenuItem Header="Launch at login" Tag="LaunchAtLogin" IsCheckable="True" Click="TitleMenu_ToggleLaunchAtLogin_Click"/>
            <MenuItem Header="Restore all icons and quit" Click="TitleMenu_RestoreAll_Click"/>
            <MenuItem Header="Quit Pickets" Click="TitleMenu_Quit_Click"/>
        </ContextMenu>

        <!-- Tooltips need a solid background; default semi-transparent styling over a blurred fence
             becomes unreadable against wallpaper. Dark pill + light text works on any color scheme. -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#F01E1E1E"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Border x:Name="OuterShell"
                CornerRadius="10"
                Background="#C8EDEDED"
                BorderBrush="#70999999"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Border x:Name="TitleShell"
                        DockPanel.Dock="Top"
                        Background="#D0DDDDDD"
                        Height="26"
                        CornerRadius="10,10,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        ContextMenu="{StaticResource TitleContextMenu}"
                        ContextMenuOpening="TitleBar_ContextMenuOpening">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TitleText"
                                   Grid.Column="0"
                                   Text="Fence"
                                   Foreground="#2C2C2C"
                                   VerticalAlignment="Center"
                                   Margin="12,0,4,0"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBox x:Name="TitleEditBox"
                                 Grid.Column="0"
                                 Visibility="Collapsed"
                                 VerticalAlignment="Center"
                                 Margin="10,1,4,1"
                                 Background="#80FFFFFF"
                                 Foreground="#2C2C2C"
                                 BorderBrush="#80999999"
                                 FontSize="14"
                                 KeyDown="TitleEditBox_KeyDown"
                                 LostFocus="TitleEditBox_LostFocus"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0">
                            <Border x:Name="UnlinkBtn"
                                    Width="22" Height="22"
                                    Margin="0,0,2,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    ToolTip="Unlink from neighbors"
                                    Visibility="Collapsed"
                                    MouseLeftButtonDown="UnlinkBtn_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#26000000"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="&#xE71B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{DynamicResource FenceItemForeground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </Border>
                            <Border x:Name="AddFenceBtn"
                                    Width="22" Height="22"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    ToolTip="New fence"
                                    MouseLeftButtonDown="AddFenceBtn_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#26000000"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="+"
                                           Foreground="{DynamicResource FenceItemForeground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,-2,0,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer x:Name="BodyScroll"
                              VerticalScrollBarVisibility="Auto"
                              AllowDrop="True"
                              Drop="ItemsHost_Drop"
                              DragOver="ItemsHost_DragOver"
                              Background="Transparent"
                              MouseLeftButtonDown="BodyScroll_MouseLeftButtonDown">
                    <ItemsControl x:Name="ItemsHost" Margin="6">
                        <ItemsControl.Resources>
                            <DataTemplate x:Key="FileItemTemplate">
                                <Border Width="{Binding CellWidth}"
                                        Height="{Binding CellHeight}"
                                        Margin="2"
                                        Padding="4"
                                        CornerRadius="4"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Opacity="{Binding CellOpacity}"
                                        MouseLeftButtonDown="Item_MouseDown"
                                        ContextMenu="{StaticResource ItemContextMenu}"
                                        ContextMenuOpening="Item_ContextMenuOpening"
                                        ToolTip="{Binding Path}">
                                    <Border.Style>
                                        <!-- Base: fully transparent. Hover adds a faint darken that reads on
                                             both light and dark fence schemes. Selection uses a translucent
                                             accent fill + matching border so the wallpaper/fence color still
                                             shows through the highlight. -->
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A000000"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#402B6AD9"/>
                                                    <Setter Property="BorderBrush" Value="#A02B6AD9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center">
                                        <Image Source="{Binding Icon}"
                                               Width="{Binding IconSize}" Height="{Binding IconSize}"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource FenceItemForeground}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="11"
                                                   MaxHeight="32"
                                                   TextTrimming="CharacterEllipsis">
                                            <!-- Soft halo behind the label so it stays readable on any wallpaper,
                                                 even when the fence body fades toward the desktop behind it. -->
                                            <TextBlock.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="1"
                                                                  Color="{DynamicResource FenceItemShadowColor}"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                            <DataTemplate x:Key="LabelItemTemplate">
                                <!-- Width bound to the WrapPanel's ActualWidth so the label fills its row;
                                     WrapPanel then auto-breaks lines before and after it. -->
                                <Border Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=WrapPanel}}"
                                        Margin="0,8,0,4"
                                        Padding="6,2"
                                        Background="#20000000"
                                        CornerRadius="3"
                                        Cursor="Hand"
                                        ContextMenu="{StaticResource LabelContextMenu}">
                                    <TextBlock Text="{Binding LabelText}"
                                               Foreground="{DynamicResource FenceItemForeground}"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="1"
                                                              Color="{DynamicResource FenceItemShadowColor}"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                            <local:FenceItemTemplateSelector x:Key="ItemSelector"
                                                             FileTemplate="{StaticResource FileItemTemplate}"
                                                             LabelTemplate="{StaticResource LabelItemTemplate}"/>
                        </ItemsControl.Resources>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplateSelector>
                            <StaticResource ResourceKey="ItemSelector"/>
                        </ItemsControl.ItemTemplateSelector>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Invisible resize thumbs (Opacity=0 keeps them hit-testable). -->
        <Thumb x:Name="ResizeRight"
               HorizontalAlignment="Right" VerticalAlignment="Stretch"
               Width="6" Cursor="SizeWE" Opacity="0"
               DragDelta="ResizeRight_DragDelta"/>
        <Thumb x:Name="ResizeBottom"
               HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
               Height="6" Cursor="SizeNS" Opacity="0"
               DragDelta="ResizeBottom_DragDelta"/>
        <Thumb x:Name="ResizeBottomRight"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Width="14" Height="14" Cursor="SizeNWSE" Opacity="0"
               DragDelta="ResizeBottomRight_DragDelta"/>
    </Grid>
</Window>
